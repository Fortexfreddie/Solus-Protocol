{
  "name": "solus-protocol-backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:migrate": "npx prisma migrate deploy",
    "db:init": "npx prisma migrate dev --name init",
    "db:clean": "npx prisma migrate reset --force && npx prisma generate",
    "smoke:vault": "tsx src/scripts/smoke-vault.ts",
    "smoke:balance": "tsx src/scripts/smoke-balance.ts",
    "smoke:phase2": "tsx src/scripts/smoke-phase2.ts",
    "smoke:phase3": "tsx src/scripts/smoke-phase3.ts",
    "smoke:phase4": "tsx src/scripts/smoke-phase4.ts",
    "smoke:phase4-pro": "tsx src/scripts/smoke-phase4-pro.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.13.1",
  "dependencies": {
    "@jup-ag/api": "^6.0.48",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@solana-program/token": "^0.11.0",
    "@solana/kit": "^6.1.0",
    "@solana/kora": "^0.1.3",
    "@solana/spl-memo": "^0.2.5",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
