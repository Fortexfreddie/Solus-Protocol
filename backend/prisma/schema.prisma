generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AgentWallet {
  id                 String   @id  // agentId: "rex", "nova", "sage"
  encryptedKey       String       // Full EncryptedVaultFile JSON (contains iv, authTag, ciphertext, salt, etc.)
  publicKey          String       // Plaintext base58 public key for display / quick lookups
  startingBalanceSol Float    @default(0)  // SOL balance at wallet creation — PnL baseline
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AuditLog {
  id      String   @id @default(cuid())
  agentId String
  event   String
  cycle   Int
  data    Json
  ts      DateTime @default(now())

  @@index([agentId])
  @@index([event])
}

model ProofRecord {
  id            String   @id @default(cuid())
  agentId       String
  cycle         Int
  hash          String   @unique
  memoSignature String
  summary       String
  payload       Json
  anchoredAt    DateTime @default(now())

  @@index([agentId])
}