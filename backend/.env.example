# System Configuration
PORT=3001
NODE_ENV=development
# NODE_ENV controls storage mode:
#   development → Filesystem storage (./wallets/*.vault.json), no DB required
#   production  → PostgreSQL storage via Prisma (wallets, audit logs, proof records)

#  Storage 
# Filesystem vault directory (development mode only).
# In production, wallets are stored in the AgentWallet PostgreSQL table instead.
VAULT_DIR=./wallets

#  Database (Supabase PostgreSQL) 
# Three connection strings for different purposes:
#
#   DATABASE_URL  — Local development database (standard port 5432)
#                   Also used by `prisma migrate dev` for local schema changes
#
#   DIRECT_URL    — Supabase direct connection (bypasses PgBouncer, port 5432)
#                   Used by `prisma migrate deploy` in production
#                   Set this in prisma.config.ts datasource for migrations
#
#   POOLER_URL    — Supabase pooled connection via PgBouncer (port 6543)
#                   Used by the app runtime in production for connection pooling
#                   This is what the live server connects through
#
# In development: only DATABASE_URL is needed (local Postgres)
# In production:  POOLER_URL is required (runtime), DIRECT_URL for migrations
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/your_DB_name?schema=public"
DIRECT_URL="your_direct_url_here"
POOLER_URL="your_pooler_url_here"

#  Security 
# Generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_MASTER_KEY=super_secure_random_master_key_change_me_in_prod

#  Solana 
# Choose ONE RPC URL. Helius is highly recommended to avoid public faucet rate limits.
# SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=your_helius_api_key

#  LLM APIs 
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

#  Funder Account (Development Only) 
# Base58 encoded private key (e.g., exported from a Phantom burner wallet). 
# Used exclusively by the `smoke-vault.ts` script to distribute Devnet SOL to the agents.
# WARNING: Never use a mainnet key here. Never commit your actual .env to version control.
FUNDER_SECRET_KEY=your_base58_phantom_private_key_here

#  Kora Paymaster Integration 
# These secrets must match the KORA_API_KEY and KORA_HMAC_SECRET in your Kora node's .env.
# KORA_API_KEY: Authenticates your backend/client with the Kora RPC node.
# KORA_HMAC_SECRET: Used by the SDK to cryptographically sign requests to prevent replay attacks.
KORA_RPC_URL=http://localhost:8080
KORA_API_KEY=your_generated_api_key
KORA_HMAC_SECRET=your_generated_hmac_secret

#  Optional: Price Data 
COINGECKO_API_KEY=your_coingecko_key_here
JUPITER_API_KEY=your_jupiter_api_key_here

# API Token provided by @BotFather. This authenticates the server with the Telegram API.
TELEGRAM_BOT_TOKEN=your_token_from_botfather

# Primary destination for automated status alerts.
# Notifications cover: Guardian Vetoes, Proof Anchoring, Execution Confirmation, and Risk Policy Failures.
TELEGRAM_CHAT_ID=your_chat_id

# Authorized User ID for administrative remote control.
# Mandatory for executing restricted commands such as /pause, /resume, and /fire via the bot.
TELEGRAM_ADMIN_ID=your_telegram_user_id_for_commands